# ─── Loyalty Nexus Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Production: inject via cloud secrets manager / Docker --env-file.

# ── Core database / cache ─────────────────────────────────────────────────────
DATABASE_URL=postgres://nexus:yourpassword@localhost:5432/loyalty_nexus?sslmode=disable
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# ── JWT auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-char-random-secret

# ── SMS / OTP (Termii) ────────────────────────────────────────────────────────
TERMII_API_KEY=

# ── AI Providers — LLM chat cascade (Groq → Gemini → DeepSeek) ───────────────
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ── Pollinations.ai ───────────────────────────────────────────────────────────
# Your secret key enables: narrate-pro (all 13 voices), photo-editor (Kontext),
# video-cinematic (Seedance), video-veo (Veo2), web-search-ai, code-helper (Qwen),
# transcribe-african (Whisper), image models (gptimage, seedream)
POLLINATIONS_SECRET_KEY=sk_8M8HiUQO5ulbyegUvbiiVDVmfEahYXvU

# ── Image generation ──────────────────────────────────────────────────────────
HF_TOKEN=                  # HuggingFace token — FLUX.1-Schnell (free, fast)
FAL_API_KEY=               # fal.ai — paid fallback for premium image/video

# ── Voice / Audio ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_TTS_KEY=      # Google Cloud TTS — 1M chars/month free
ELEVENLABS_API_KEY=        # ElevenLabs TTS — premium quality
ELEVENLABS_VOICE_ID=       # defaults to Rachel voice if not set

# ── Transcription ─────────────────────────────────────────────────────────────
ASSEMBLY_AI_KEY=           # AssemblyAI — English transcription (free $50 credit)

# ── Translation ───────────────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=  # Google Translate API — Yoruba/Hausa/Igbo/French

# ── Mobile Money (Flutterwave / MoMo) ────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# ── File storage ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET_NAME=nexus-studio-assets

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development    # development | staging | production
