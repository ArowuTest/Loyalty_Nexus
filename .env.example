# ═══════════════════════════════════════════════════════════════
# Loyalty Nexus — Environment Variables
# Copy to .env and populate all values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ─── Core Infrastructure ───────────────────────────────────────
PORT=8080
OPERATION_MODE=independent                    # independent | integrated

# ─── Database ──────────────────────────────────────────────────
DB_USER=nexus
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=loyalty_nexus
DATABASE_URL=postgres://nexus:CHANGE_ME@localhost:5432/loyalty_nexus?sslmode=disable

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── NATS JetStream ────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Security (generate with: openssl rand -hex 32) ───────────
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
AES_256_KEY=CHANGE_ME_64_CHAR_HEX              # Exactly 64 hex chars = 32 bytes

# ─── Paystack (Independent Mode) ───────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_CHANGE_ME
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_CHANGE_ME

# ─── VTPass (Airtime/Data provisioning) ────────────────────────
VTPASS_API_KEY=CHANGE_ME
VTPASS_PUBLIC_KEY=CHANGE_ME

# ─── MTN MoMo ──────────────────────────────────────────────────
MOMO_SUBSCRIPTION_KEY=CHANGE_ME
MOMO_API_USER=CHANGE_ME
MOMO_API_KEY=CHANGE_ME
MOMO_TARGET_ENV=sandbox                        # sandbox | production

# ─── AI Studio: Chat (Free tier) ───────────────────────────────
GROQ_API_KEY=gsk_CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
DEEPSEEK_API_KEY=CHANGE_ME

# ─── AI Studio: Image & Video ──────────────────────────────────
HUGGING_FACE_API_KEY=hf_CHANGE_ME
FAL_AI_API_KEY=CHANGE_ME

# ─── AI Studio: Knowledge (NotebookLM via notebooklm-py) ───────
NOTEBOOK_LM_EMAIL=CHANGE_ME@gmail.com          # Google account for notebooklm-py
NOTEBOOK_LM_PASSWORD=CHANGE_ME                 # App password (2FA enabled)

# ─── AI Studio: Document Processing ────────────────────────────
ASSEMBLY_AI_API_KEY=CHANGE_ME
GOOGLE_TRANSLATE_API_KEY=CHANGE_ME
GOOGLE_TTS_API_KEY=CHANGE_ME

# ─── AI Studio: Audio ──────────────────────────────────────────
MUBERT_API_KEY=CHANGE_ME

# ─── File Storage (AWS S3) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-west-1
S3_BUCKET_NAME=loyalty-nexus-assets
S3_ASSET_URL_PREFIX=https://assets.loyalty-nexus.ai

# ─── Notifications ─────────────────────────────────────────────
TERMII_API_KEY=CHANGE_ME
AFRICAS_TALKING_API_KEY=CHANGE_ME

# ─── Digital Passport (Apple Wallet) ───────────────────────────
APPLE_CERT_BASE64=CHANGE_ME                    # base64-encoded .p12 cert
APPLE_CERT_PASSWORD=CHANGE_ME
APPLE_PASS_TYPE_ID=pass.ai.loyaltynexus.passport
APPLE_TEAM_ID=CHANGE_ME

# ─── Digital Passport (Google Wallet) ──────────────────────────
GOOGLE_WALLET_ISSUER_ID=CHANGE_ME
GOOGLE_WALLET_CLASS_ID=CHANGE_ME
GOOGLE_WALLET_CLIENT_EMAIL=CHANGE_ME@iam.gserviceaccount.com
GOOGLE_WALLET_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nCHANGE_ME\n-----END EC PRIVATE KEY-----

# ─── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
