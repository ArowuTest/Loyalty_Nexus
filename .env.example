# .env.example - Loyalty Nexus Infrastructure
# Copy this to .env and fill in real production/test keys

# --- CORE INFRASTRUCTURE ---
PORT=8080
DATABASE_URL=postgres://user:pass@localhost:5432/loyalty_nexus?sslmode=disable
REDIS_URL=localhost:6379
OPERATION_MODE=independent # independent or integrated

# --- PAYMENT & PROVISIONING (Independent Mode) ---
PAYSTACK_SECRET_KEY=sk_test_...
VTPASS_API_KEY=...
VTPASS_PUBLIC_KEY=...

# --- AI STUDIO FEED PROVIDERS ---
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=...
FAL_AI_API_KEY=...
HUGGING_FACE_API_KEY=...
NOTEBOOK_LM_KEY=...
ASSEMBLY_AI_API_KEY=...

# --- NOTIFICATIONS ---
TERMII_API_KEY=...

# --- DIGITAL PASSPORT (WALLET) ---
APPLE_CERTIFICATE_BASE64=...
APPLE_CERTIFICATE_PASSWORD=...
GOOGLE_WALLET_ISSUER_ID=...
GOOGLE_WALLET_CLIENT_EMAIL=...
GOOGLE_WALLET_PRIVATE_KEY=...

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
